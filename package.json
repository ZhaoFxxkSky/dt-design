{
  "name": "@dtjoy/dt-design",
  "version": "1.1.2",
  "packageManager": "pnpm@11.4.0+sha512.f0febc7e37552ab485494a914241b338e0b3580b93d54ce31f00933015880863129038a1b4ae4e414a0ee63ac35bf21197e990172c4a68256450b5636310968f",
  "description": "react-component",
  "author": {
    "name": "夕颜",
    "email": "wx-zhaog@dtjoy.com",
    "url": "https://github.com/ZhaoFxxkSky/dt-design"
  },
  "license": "MIT",
  "repository": "https://github.com/ZhaoFxxkSky/dt-design",
  "keywords": [
    "react",
    "react-component",
    "ui-library",
    "typescript",
    "ant-design"
  ],
  "sideEffects": [
    "dist/*",
    "es/**/style/*",
    "lib/**/style/*",
    "**/style/*"
  ],
  "main": "lib/index.js",
  "module": "es/index.js",
  "unpkg": "dist/dt-design.min.js",
  "typings": "es/index.d.ts",
  "files": [
    "dist",
    "es",
    "lib"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "npm run dev",
    "dev": "dumi dev",
    "build": "father build",
    "build:dts": "tsc -p tsconfig.build.json",
    "build:watch": "father dev",
    "format": "biome format --write .",
    "lint:script": "eslint . --cache",
    "lint:biome": "biome lint",
    "lint:pkg": "publint",
    "biome": "biome check --write",
    "test": "jest",
    "docs:build": "dumi build",
    "prepare": "husky install && dumi setup",
    "doctor": "father doctor",
    "lint": "npm run tsc && npm run lint:script && npm run lint:biome",
    "lint:es-fix": "eslint \"components/**/*.{js,jsx,ts,tsx}\" \".dumi/**/*.{js,jsx,ts,tsx}\" --fix",
    "lint:css-fix": "stylelint \"components/**/*.{css,less,scss}\" \".dumi/**/*.{css,less,scss}\" --fix",
    "lint:css": "stylelint \"components/**/*.{css,less,scss}\" \".dumi/**/*.{css,less,scss}\"",
    "lint:es": "eslint \"components/**/*.{js,jsx,ts,tsx}\" \".dumi/**/*.{js,jsx,ts,tsx}\"",
    "prepublishOnly": "npm run build && npm run build:dts",
    "deploy": "npm run docs:build && gh-pages -d docs-dist",
    "release": "./scripts/release.sh",
    "tsc": "tsc --noEmit",
    "tsc:old": "tsc --noEmit -p tsconfig-old-react.json"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "antd": "^4.x",
    "react": ">=16.9.0",
    "react-dom": ">=16.9.0"
  },
  "dependencies": {
    "@ant-design/icons": "^4.8.3",
    "@dtinsight/dt-utils": "^1.3.1",
    "clsx": "^2.1.1",
    "immer": "~10.1.1",
    "lodash": "^4.17.21",
    "rc-drawer": "~5.1.0",
    "rc-resize-observer": "^1.4.3",
    "rc-tree": "5.7.12",
    "rc-util": "^5.44.4",
    "rc-virtual-list": "^3.4.13"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.1.0",
    "@biomejs/biome": "^2.3.10",
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@eslint-react/eslint-plugin": "^5.16.1",
    "@faker-js/faker": "^10.5.0",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.0",
    "@npmcli/run-script": "^11.0.0",
    "@prettier/sync": "^0.6.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/react-hooks": "^8.0.1",
    "@testing-library/user-event": "^14.4.3",
    "@types/jest": "^30.0.0",
    "@types/lodash": "^4.17.12",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/react-resizable": "^4.0.0",
    "@types/react-syntax-highlighter": "~15.5.13",
    "@types/shortid": "^2.2.0",
    "@types/showdown": "^2.0.6",
    "@types/testing-library__jest-dom": "^6.0.0",
    "ant-design-testing": "^2.0.0",
    "babel-plugin-import": "^1.13.8",
    "cz-conventional-changelog": "^3.3.0",
    "dumi": "~2.4.21",
    "eslint": "^10.7.0",
    "eslint-plugin-compat": "^7.0.2",
    "eslint-plugin-jest": "^29.12.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "father": "4.6.13",
    "gh-pages": "^6.3.0",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "ko-lint-config": "2.2.21",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.5",
    "publint": "^0.3.21",
    "rc-motion": "2.6.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-test-renderer": "^19.2.7",
    "resize-observer-polyfill": "^1.5.1",
    "standard-version": "^9.5.0",
    "stylelint": "^17.14.0",
    "stylelint-config-prettier": "^9.0.2",
    "stylelint-config-rational-order": "^0.1.2",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-declaration-block-no-ignored-properties": "^3.0.0",
    "stylelint-order": "^8.1.1",
    "ts-jest": "^29.0.3",
    "typescript": "~7.0.2"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "resolutions": {
    "rc-motion": "2.6.2"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,css,mjs,json}": [
      "biome check --write --no-errors-on-unmatched",
      "eslint"
    ],
    "*.{md,yml}": [
      "prettier --ignore-unknown --write"
    ]
  }
}